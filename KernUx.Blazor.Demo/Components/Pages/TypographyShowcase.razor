@page "/components/typography"
@using KernUx.Blazor.Demo.Components.Shared

<PageTitle>Typografie - KernUx.Blazor Showcase</PageTitle>

<KernContainer>
    <KernHeading Level="HeadingLevel.Large" Element="h1">Typografie</KernHeading>
    <KernBody Muted="true">Alle KERN-Typografie-Komponenten in ihren wichtigsten Varianten.</KernBody>

    <ComponentSection Title="KernHeading" Description="Visuelle Heading-Stufen sind vom semantischen HTML-Element entkoppelt.">
        <KernHeading Level="HeadingLevel.Display" Element="h1">Display</KernHeading>
        <KernHeading Level="HeadingLevel.XLarge" Element="h2">XLarge</KernHeading>
        <KernHeading Level="HeadingLevel.Large" Element="h3">Large</KernHeading>
        <KernHeading Level="HeadingLevel.Medium" Element="h4">Medium</KernHeading>
        <KernHeading Level="HeadingLevel.Small" Element="h5">Small</KernHeading>
    </ComponentSection>

    <ComponentSection Title="KernTitle" Description="Titelvarianten für Karten, Abschnitte und Zusammenfassungen.">
        <KernTitle Size="TitleSize.Small">Title Small</KernTitle>
        <KernTitle Size="TitleSize.Default">Title Default</KernTitle>
        <KernTitle Size="TitleSize.Large">Title Large</KernTitle>
    </ComponentSection>

    <ComponentSection Title="KernBody" Description="Fließtext mit Größen- und Darstellungsvarianten.">
        <KernBody>Standardtext</KernBody>
        <KernBody Bold="true">Fetter Text</KernBody>
        <KernBody Muted="true">Gedimmter Text</KernBody>
        <KernBody Size="Size.Small">Kleiner Text</KernBody>
        <KernBody Size="Size.Large">Großer Text</KernBody>
    </ComponentSection>

    <ComponentSection Title="KernLabel" Description="Labels für Formulare, optional mit Optional-Kennzeichnung.">
        <KernLabel>Standard Label</KernLabel>
        <KernLabel Optional="true">Label mit Optional-Text</KernLabel>
        <KernLabel Size="Size.Small">Kleines Label</KernLabel>
        <KernLabel Size="Size.Large">Großes Label</KernLabel>
    </ComponentSection>

    <ComponentSection Title="KernPreline und KernSubline" Description="Typische Vor- und Unterzeilen für strukturierte Inhalte.">
        <KernPreline Size="Size.Small">Preline Small</KernPreline>
        <KernPreline>Preline Default</KernPreline>
        <KernPreline Size="Size.Large">Preline Large</KernPreline>

        <KernSubline Size="Size.Small">Subline Small</KernSubline>
        <KernSubline>Subline Default</KernSubline>
        <KernSubline Size="Size.Large">Subline Large</KernSubline>
    </ComponentSection>
</KernContainer>
