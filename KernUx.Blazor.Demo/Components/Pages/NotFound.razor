@page "/not-found"
@layout MainLayout

<PageTitle>Seite nicht gefunden - KernUx.Blazor Showcase</PageTitle>

<KernContainer>
    <KernRow>
        <KernCol>
            <KernHeading Level="HeadingLevel.Large" Element="h1">Seite nicht gefunden</KernHeading>
            <KernBody>
                Die angeforderte Seite existiert nicht oder wurde verschoben.
            </KernBody>

            <KernAlert Type="AlertType.Warning" Title="Hinweis">
                Bitte prüfen Sie die URL oder verwenden Sie die Navigation links.
            </KernAlert>

            <KernRow>
                <KernCol Span="6" SpanMd="4">
                    <KernButton Variant="ButtonVariant.Primary" Type="button" OnClick="GoHome" Block="true">
                        Zur Startseite
                    </KernButton>
                </KernCol>
            </KernRow>
        </KernCol>
    </KernRow>
</KernContainer>

@code {
    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private Task GoHome(MouseEventArgs _)
    {
        NavigationManager.NavigateTo("/");
        return Task.CompletedTask;
    }
}
