@page "/components/buttons"
@rendermode InteractiveServer
@using KernUx.Blazor.Demo.Components.Shared

<PageTitle>Buttons - KernUx.Blazor Showcase</PageTitle>

<KernContainer>
    <KernHeading Level="HeadingLevel.Large" Element="h1">Buttons</KernHeading>
    <KernBody Muted="true">Varianten, Zustände und Event-Handling mit <code>KernButton</code>.</KernBody>

    <ComponentSection Title="Varianten" Description="Primary, Secondary und Tertiary.">
        <VariantRow>
            <KernCol Span="4"><KernButton Variant="ButtonVariant.Primary">Primary</KernButton></KernCol>
            <KernCol Span="4"><KernButton Variant="ButtonVariant.Secondary">Secondary</KernButton></KernCol>
            <KernCol Span="4"><KernButton Variant="ButtonVariant.Tertiary">Tertiary</KernButton></KernCol>
        </VariantRow>
    </ComponentSection>

    <ComponentSection Title="Icons" Description="Icons links, rechts und Icon-Only mit Aria-Label.">
        <VariantRow>
            <KernCol Span="4"><KernButton Icon="KernIconGlyph.ArrowBack" IconPosition="IconPosition.Left">Zurück</KernButton></KernCol>
            <KernCol Span="4"><KernButton Icon="KernIconGlyph.ArrowForward" IconPosition="IconPosition.Right">Weiter</KernButton></KernCol>
            <KernCol Span="4">
                <KernButton Icon="KernIconGlyph.Add" IconOnly="true" Title="Eintrag hinzufügen" AriaLabel="Eintrag hinzufügen">
                    Hinzufügen
                </KernButton>
            </KernCol>
        </VariantRow>
    </ComponentSection>

    <ComponentSection Title="Zustände" Description="Disabled und Block-Button.">
        <VariantRow>
            <KernCol Span="6"><KernButton Disabled="true">Deaktiviert</KernButton></KernCol>
            <KernCol Span="6"><KernButton Block="true">Block-Button</KernButton></KernCol>
        </VariantRow>
    </ComponentSection>

    <ComponentSection Title="Interaktion" Description="Click-Events und Submit-Demo.">
        <VariantRow>
            <KernCol Span="6">
                <KernButton Variant="ButtonVariant.Primary" OnClick="IncreaseCounter">Klick mich</KernButton>
            </KernCol>
            <KernCol Span="6">
                <KernBody>Klickzähler: <strong>@_clickCount</strong></KernBody>
            </KernCol>
        </VariantRow>

        <form @onsubmit="HandleSubmit">
            <KernButton Type="submit" Variant="ButtonVariant.Secondary">Als Submit absenden</KernButton>
        </form>

        @if (_submitted)
        {
            <KernAlert Type="AlertType.Success" Title="Formular abgeschickt">
                Der Submit-Button hat erfolgreich ein Formularereignis ausgelöst.
            </KernAlert>
        }
    </ComponentSection>
</KernContainer>

@code {
    private int _clickCount;
    private bool _submitted;

    private Task IncreaseCounter(MouseEventArgs _)
    {
        _clickCount++;
        return Task.CompletedTask;
    }

    private Task HandleSubmit()
    {
        _submitted = true;
        return Task.CompletedTask;
    }
}
