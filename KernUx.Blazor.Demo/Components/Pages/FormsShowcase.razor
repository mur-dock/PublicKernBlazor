@page "/components/forms"


@using System.Globalization

<PageTitle>Formulare - KernUx.Blazor Showcase</PageTitle>

<KernContainer>
    <KernHeading Level="HeadingLevel.Large" Element="h1">Formularelemente</KernHeading>
    <KernBody Muted="true">Übersicht der KERN-Form-Komponenten mit Binding, Hinweisen und Fehlerzuständen.</KernBody>

    <ComponentSection Title="Textbasierte Eingaben" Description="Text, E-Mail, Passwort, Telefon, URL und Number.">
        <KernInputText Label="Name" Value="@_name" ValueChanged="@(value => _name = value)" Hint="Bitte vollständigen Namen angeben." />
        <KernInputEmail Label="E-Mail" Value="@_email" ValueChanged="@(value => _email = value)" />
        <KernInputPassword Label="Passwort" Value="@_password" ValueChanged="@(value => _password = value)" Optional="true" />
        <KernInputTel Label="Telefon" Value="@_phone" ValueChanged="@(value => _phone = value)" />
        <KernInputUrl Label="Webseite" Value="@_website" ValueChanged="@(value => _website = value)" Optional="true" />
        <KernInputNumber Label="Hausnummer" Value="@_houseNumber" ValueChanged="@(value => _houseNumber = value)" />
    </ComponentSection>

    <ComponentSection Title="Spezialfelder" Description="Datum, Währung, Datei und Textarea.">
        <KernInputDate Label="Geburtsdatum" Day="@_birthDay" DayChanged="@(value => _birthDay = value)" Month="@_birthMonth" MonthChanged="@(value => _birthMonth = value)" Year="@_birthYear" YearChanged="@(value => _birthYear = value)" />

        <KernInputCurrency Label="Monatliches Nettoeinkommen" Value="@_income" ValueChanged="@(value => _income = value)" Hint="Eingabe im deutschen Zahlenformat." />

        <KernInputFile Label="Nachweis hochladen" Hint="PDF oder Bilddatei." Accept=".pdf,.png,.jpg,.jpeg" OnFileSelected="HandleFileSelected" />

        <KernTextarea Label="Bemerkung" Value="@_notes" ValueChanged="@(value => _notes = value)" Rows="5" />

        @if (!string.IsNullOrWhiteSpace(_selectedFileName))
        {
            <KernAlert Type="AlertType.Info" Title="Datei gewählt">@_selectedFileName</KernAlert>
        }
    </ComponentSection>

    <ComponentSection Title="Select, Checkbox, Radio" Description="Einfach- und Mehrfachauswahl mit typsicheren Records.">
        <KernSelect Label="Bundesland" Value="@_selectedState" ValueChanged="@(value => _selectedState = value)" Options="StateOptions" />

        <KernCheckbox Label="Ich akzeptiere die Datenschutzhinweise" Checked="@_privacyAccepted" CheckedChanged="@(value => _privacyAccepted = value)" />

        <KernCheckboxList Legend="Leistungsschwerpunkte" Items="FocusOptions" SelectedValues="@_selectedFocuses" SelectedValuesChanged="OnFocusesChanged" />

        <KernRadioGroup Legend="Kontaktweg" Items="ContactOptions" Value="@_contactMethod" ValueChanged="@(value => _contactMethod = value)" Horizontal="true" />
    </ComponentSection>

    <ComponentSection Title="Fieldset und KernFormField" Description="Beispiel für gruppierte Felder und ein manuell gerendertes Eingabefeld.">
        <KernFieldset Legend="Technische Einstellungen" Hint="Dieses Beispiel nutzt KernFieldset direkt.">
            <KernCheckbox Label="Benachrichtigungen aktivieren" Checked="@_notifications" CheckedChanged="@(value => _notifications = value)" />
            <KernCheckbox Label="Dunkles Theme bevorzugen" Checked="@_preferDark" CheckedChanged="@(value => _preferDark = value)" />
        </KernFieldset>

        <KernFormField Label="Benutzerdefinierter Wert"
                       Hint="RenderFragment über FieldContent."
                       InputId="custom-form-field"
                       FieldContent="RenderCustomField" />

        <KernSummary Title="Aktueller Formularstatus" Number="1" EditLabel="Zur Eingabe" EditHref="#">
            <KernDescriptionList Layout="DescriptionListLayout.Column">
                <KernDescriptionItem Key="Name" Value="@(_name ?? "-")" />
                <KernDescriptionItem Key="E-Mail" Value="@(_email ?? "-")" />
                <KernDescriptionItem Key="Bundesland" Value="@(_selectedState ?? "-")" />
                <KernDescriptionItem Key="Kontaktweg" Value="@(_contactMethod ?? "-")" />
            </KernDescriptionList>
        </KernSummary>
    </ComponentSection>
</KernContainer>

@code {
    private string? _name;
    private string? _email;
    private string? _password;
    private string? _phone;
    private string? _website;
    private string? _houseNumber;

    private string? _birthDay;
    private string? _birthMonth;
    private string? _birthYear;

    private decimal? _income;
    private string? _notes;
    private string? _selectedFileName;

    private string? _selectedState = "be";
    private bool _privacyAccepted;
    private IReadOnlyCollection<string> _selectedFocuses = ["digitalisierung"];
    private string? _contactMethod = "email";

    private bool _notifications;
    private bool _preferDark;
    private string? _customFieldValue;

    private static readonly IReadOnlyList<KernSelectOption> StateOptions =
    [
        new("bw", "Baden-Wuerttemberg"),
        new("by", "Bayern"),
        new("be", "Berlin"),
        new("hh", "Hamburg")
    ];

    private static readonly IReadOnlyList<KernCheckboxItem> FocusOptions =
    [
        new("digitalisierung", "Digitalisierung"),
        new("familie", "Familie"),
        new("arbeit", "Arbeit"),
        new("mobilitaet", "Mobilitaet")
    ];

    private static readonly IReadOnlyList<KernRadioItem> ContactOptions =
    [
        new("email", "E-Mail"),
        new("phone", "Telefon"),
        new("letter", "Post")
    ];

    private RenderFragment<KernFormFieldContext> RenderCustomField => context => @<input id="@context.InputId"
        class="kern-form-input__input"
        type="text"
        value="@_customFieldValue"
        aria-describedby="@context.AriaDescribedBy"
        @oninput="HandleCustomFieldInput" />;

    private Task OnFocusesChanged(IReadOnlyCollection<string> values)
    {
        _selectedFocuses = values;
        return Task.CompletedTask;
    }

    private Task HandleFileSelected(InputFileChangeEventArgs args)
    {
        _selectedFileName = args.FileCount > 0 ? args.File.Name : null;
        return Task.CompletedTask;
    }

    private Task HandleCustomFieldInput(ChangeEventArgs args)
    {
        _customFieldValue = Convert.ToString(args.Value, CultureInfo.InvariantCulture);
        return Task.CompletedTask;
    }
}
