@inherits LayoutComponentBase
@inject ThemeService ThemeService

<KernThemeProvider Theme="KernTheme.Light">
    <KernKopfzeile />

    <header class="demo-header">
        <KernContainer>
            <KernRow JustifyContent="JustifyContent.Between" AlignItems="AlignItems.Center">
                <KernCol Span="9">
                    <KernPreline>KERN Design System</KernPreline>
                    <KernTitle Size="TitleSize.Large">KernUx.Blazor Showcase</KernTitle>
                </KernCol>
                <KernCol Span="3" class="demo-header__actions">
                    <KernButton Variant="ButtonVariant.Tertiary"
                                Icon="KernIconGlyph.BrightnessMedium"
                                IconOnly="true"
                                Title="Theme wechseln"
                                AriaLabel="Theme wechseln"
                                OnClick="ToggleTheme">
                        Theme wechseln
                    </KernButton>
                </KernCol>
            </KernRow>
        </KernContainer>
    </header>

    <KernContainer>
        <KernRow>
            <KernCol Span="3">
                <DemoNavMenu />
            </KernCol>
            <KernCol Span="9">
                <main>
                    @Body
                </main>
            </KernCol>
        </KernRow>
    </KernContainer>
</KernThemeProvider>

<div id="blazor-error-ui" data-nosnippet>
    Ein unbehandelter Fehler ist aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private Task ToggleTheme()
    {
        ThemeService.Toggle();
        return Task.CompletedTask;
    }
}
