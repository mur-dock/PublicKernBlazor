@namespace KernUx.Blazor.Components.Content

<div class="kern-description-list-item" @attributes="AdditionalAttributes">
    <dt class="kern-description-list-item__key">@Key</dt>
    <dd class="kern-description-list-item__value">
        @if (ChildContent is not null)
        {
            @ChildContent
        }
        else
        {
            @Value
        }
    </dd>
</div>

@code {
    /// <summary>Schlüssel (Key) des Key-Value-Paares.</summary>
    [Parameter]
    public string Key { get; set; } = string.Empty;

    /// <summary>Einfacher Textwert. Wird ignoriert, wenn <see cref="ChildContent"/> gesetzt ist.</summary>
    [Parameter]
    public string? Value { get; set; }

    /// <summary>Komplexer Inhalt für den Wert (überschreibt <see cref="Value"/>).</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Zusätzliche HTML-Attribute für das Wrapper-<c>&lt;div&gt;</c>.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }
}

