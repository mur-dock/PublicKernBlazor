@namespace KernUx.Blazor.Components.Content
@inject IdGeneratorService IdGenerator

<li class="kern-task-list__item" @attributes="AdditionalAttributes">
    @if (!string.IsNullOrWhiteSpace(Number))
    {
        <span class="kern-number">@Number</span>
    }
    <div class="kern-task-list__title" id="@ResolvedTitleId">
        @if (!string.IsNullOrWhiteSpace(Href))
        {
            @* aria-describedby wird nur gesetzt, wenn StatusContent tatsächlich gerendert wird.
               Ein aria-describedby das auf eine nicht existierende ID zeigt, ist ein WCAG 1.3.1-Fehler
               und kann Screenreader verwirren. *@
            <a href="@Href"
               class="kern-link kern-link--stretched"
               aria-describedby="@(StatusContent is null ? null : ResolvedStatusId)">@Title</a>
        }
        else
        {
            @Title
        }
        @if (StatusContent is not null)
        {
            <div class="kern-task-list__status" id="@ResolvedStatusId">
                @StatusContent
            </div>
        }
    </div>
</li>

@code {
    private string? _generatedId;

    /// <summary>Optionale Nummer des Eintrags.</summary>
    [Parameter]
    public string? Number { get; set; }

    /// <summary>Titel des Aufgabeneintrags.</summary>
    [Parameter]
    public string Title { get; set; } = string.Empty;

    /// <summary>Optionaler Link-Href für die Aufgabe.</summary>
    [Parameter]
    public string? Href { get; set; }

    /// <summary>Status-Anzeige (typischerweise ein <c>KernBadge</c>).</summary>
    [Parameter]
    public RenderFragment? StatusContent { get; set; }

    /// <summary>Explizite ID für diesen Eintrag.</summary>
    [Parameter]
    public string? Id { get; set; }

    /// <summary>Zusätzliche HTML-Attribute.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedId => string.IsNullOrWhiteSpace(Id) ? _generatedId ?? "kern-task" : Id;
    private string ResolvedTitleId => $"{ResolvedId}-title";
    private string ResolvedStatusId => $"{ResolvedId}-status";

    protected override void OnInitialized()
    {
        _generatedId = IdGenerator.Create("kern-task");
    }
}

