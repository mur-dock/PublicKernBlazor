@page "/components/feedback"


@using PublicKernBlazor.Demo.Components.Shared

<PageTitle>Feedback - PublicKernBlazor.Components Showcase</PageTitle>

<KernContainer>
    <KernHeading Level="HeadingLevel.Large" Element="h1">Feedback-Komponenten</KernHeading>
    <KernBody Muted="true">Alerts, Badges, Loader und Progress für Statuskommunikation.</KernBody>

    <ComponentSection Title="Alerts" Description="Info, Success, Warning und Danger.">
        <KernAlert Type="AlertType.Info" Title="Information">Sachverhalt wurde gespeichert.</KernAlert>
        <KernAlert Type="AlertType.Success" Title="Erfolg">Antrag wurde erfolgreich übermittelt.</KernAlert>
        <KernAlert Type="AlertType.Warning" Title="Hinweis">Bitte prüfen Sie die fehlenden Pflichtfelder.</KernAlert>
        <KernAlert Type="AlertType.Danger" Title="Fehler">Das Formular konnte nicht gespeichert werden.</KernAlert>
    </ComponentSection>

    <ComponentSection Title="Badges" Description="Semantische Varianten mit optionalen Icons.">
        <VariantRow>
            <KernCol Span="3"><KernBadge Variant="BadgeVariant.Info" Icon="KernIconGlyph.Info">Info</KernBadge></KernCol>
            <KernCol Span="3"><KernBadge Variant="BadgeVariant.Success" Icon="KernIconGlyph.Success">Erfolgreich</KernBadge></KernCol>
            <KernCol Span="3"><KernBadge Variant="BadgeVariant.Warning" Icon="KernIconGlyph.Warning">In Prüfung</KernBadge></KernCol>
            <KernCol Span="3"><KernBadge Variant="BadgeVariant.Danger" Icon="KernIconGlyph.Danger">Fehler</KernBadge></KernCol>
        </VariantRow>
    </ComponentSection>

    <ComponentSection Title="Loader" Description="Sichtbarkeit per Toggle steuern.">
        <KernButton OnClick="ToggleLoader">@(_isLoading ? "Loader ausblenden" : "Loader anzeigen")</KernButton>
        <div class="demo-loader-host">
            <KernLoader Visible="_isLoading" ScreenReaderText="Daten werden geladen" />
        </div>
    </ComponentSection>

    <ComponentSection Title="Progress" Description="Statischer und interaktiver Fortschritt.">
        <KernProgress Value="72" Max="100" Label="Bearbeitungsstand (statisch)" />

        <KernProgress Value="_progressValue" Max="100" Label="Interaktiver Fortschritt" LabelBelow="true" />
        <VariantRow>
            <KernCol Span="4"><KernButton OnClick="IncreaseProgress">+10</KernButton></KernCol>
            <KernCol Span="4"><KernButton Variant="ButtonVariant.Secondary" OnClick="DecreaseProgress">-10</KernButton></KernCol>
            <KernCol Span="4"><KernButton Variant="ButtonVariant.Tertiary" OnClick="ResetProgress">Reset</KernButton></KernCol>
        </VariantRow>
    </ComponentSection>
</KernContainer>

@code {
    private bool _isLoading;
    private int _progressValue = 30;

    private Task ToggleLoader(MouseEventArgs _)
    {
        _isLoading = !_isLoading;
        return Task.CompletedTask;
    }

    private Task IncreaseProgress(MouseEventArgs _)
    {
        _progressValue = Math.Min(100, _progressValue + 10);
        return Task.CompletedTask;
    }

    private Task DecreaseProgress(MouseEventArgs _)
    {
        _progressValue = Math.Max(0, _progressValue - 10);
        return Task.CompletedTask;
    }

    private Task ResetProgress(MouseEventArgs _)
    {
        _progressValue = 0;
        return Task.CompletedTask;
    }
}
