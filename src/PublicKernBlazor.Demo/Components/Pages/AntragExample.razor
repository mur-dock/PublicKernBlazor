@page "/examples/antrag"

<PageTitle>Antragsstrecke - PublicKernBlazor.Components Showcase</PageTitle>

<KernContainer>
    <KernHeading Level="HeadingLevel.Large" Element="h1">Praxisbeispiel: Antragsstrecke</KernHeading>
    <KernBody Muted="true">
        Mehrstufiger Antrag mit Validierung, Zusammenfassung und Bestätigung.
        Demonstriert State-Management über mehrere Schritte hinweg.
    </KernBody>

    @if (_currentStep < 4)
    {
        <KernProgress Value="_currentStep" Max="4" Label="Fortschritt" />
    }

    @if (_currentStep == 1)
    {
        <ComponentSection Title="Schritt 1 – Persönliche Daten" Description="Bitte geben Sie Ihre persönlichen Daten ein.">
            <KernFieldset Legend="Anrede">
                <KernRadioGroup Items="_anredeOptions"
                                Value="@_anrede"
                                ValueChanged="@(value => _anrede = value)"
                                Horizontal="true"
                                Legend="" />
            </KernFieldset>

            <KernInputText Label="Vorname"
                           Value="@_vorname"
                           ValueChanged="@(value => _vorname = value)"
                           Error="@GetValidationError(nameof(_vorname))" />

            <KernInputText Label="Nachname"
                           Value="@_nachname"
                           ValueChanged="@(value => _nachname = value)"
                           Error="@GetValidationError(nameof(_nachname))" />

            <KernInputEmail Label="E-Mail-Adresse"
                            Value="@_email"
                            ValueChanged="@(value => _email = value)"
                            Error="@GetValidationError(nameof(_email))" />

            <KernInputTel Label="Telefon"
                          Value="@_telefon"
                          ValueChanged="@(value => _telefon = value)"
                          Optional="true" />

            <KernInputDate Label="Geburtsdatum"
                           Day="@_geburtstagTag"
                           DayChanged="@(value => _geburtstagTag = value)"
                           Month="@_geburtstagMonat"
                           MonthChanged="@(value => _geburtstagMonat = value)"
                           Year="@_geburtstagJahr"
                           YearChanged="@(value => _geburtstagJahr = value)"
                           Error="@GetValidationError(nameof(_geburtstagTag))" />

            <KernRow>
                <KernCol Span="12" SpanMd="6">
                    <KernButton Variant="ButtonVariant.Secondary" OnClick="CancelAntrag" Block="true">Abbrechen</KernButton>
                </KernCol>
                <KernCol Span="12" SpanMd="6">
                    <KernButton Variant="ButtonVariant.Primary" OnClick="NextStep" Block="true">Weiter</KernButton>
                </KernCol>
            </KernRow>
        </ComponentSection>
    }
    else if (_currentStep == 2)
    {
        <ComponentSection Title="Schritt 2 – Adressdaten" Description="Bitte geben Sie Ihre Adressdaten ein.">
            <KernInputText Label="Straße"
                           Value="@_strasse"
                           ValueChanged="@(value => _strasse = value)"
                           Error="@GetValidationError(nameof(_strasse))" />

            <KernRow>
                <KernCol Span="12" SpanMd="4">
                    <KernInputText Label="Hausnummer"
                                   Value="@_hausnummer"
                                   ValueChanged="@(value => _hausnummer = value)"
                                   Error="@GetValidationError(nameof(_hausnummer))" />
                </KernCol>
                <KernCol Span="12" SpanMd="4">
                    <KernInputText Label="PLZ"
                                   Value="@_plz"
                                   ValueChanged="@(value => _plz = value)"
                                   Error="@GetValidationError(nameof(_plz))" />
                </KernCol>
                <KernCol Span="12" SpanMd="4">
                    <KernInputText Label="Ort"
                                   Value="@_ort"
                                   ValueChanged="@(value => _ort = value)"
                                   Error="@GetValidationError(nameof(_ort))" />
                </KernCol>
            </KernRow>

            <KernSelect Label="Bundesland"
                        Options="_bundeslaender"
                        Value="@_bundesland"
                        ValueChanged="@(value => _bundesland = value)"
                        Error="@GetValidationError(nameof(_bundesland))" />

            <KernCheckbox Label="Ich habe eine abweichende Postadresse"
                          Checked="@_abweichendeAdresse"
                          CheckedChanged="@(value => _abweichendeAdresse = value)" />

            @if (_abweichendeAdresse)
            {
                <KernFieldset Legend="Abweichende Postadresse">
                    <KernInputText Label="Straße"
                                   Value="@_postStrasse"
                                   ValueChanged="@(value => _postStrasse = value)" />

                    <KernRow>
                        <KernCol Span="12" SpanMd="4">
                            <KernInputText Label="Hausnummer"
                                           Value="@_postHausnummer"
                                           ValueChanged="@(value => _postHausnummer = value)" />
                        </KernCol>
                        <KernCol Span="12" SpanMd="4">
                            <KernInputText Label="PLZ"
                                           Value="@_postPlz"
                                           ValueChanged="@(value => _postPlz = value)" />
                        </KernCol>
                        <KernCol Span="12" SpanMd="4">
                            <KernInputText Label="Ort"
                                           Value="@_postOrt"
                                           ValueChanged="@(value => _postOrt = value)" />
                        </KernCol>
                    </KernRow>
                </KernFieldset>
            }

            <KernRow>
                <KernCol Span="12" SpanMd="6">
                    <KernButton Variant="ButtonVariant.Secondary" OnClick="PreviousStep" Block="true">Zurück</KernButton>
                </KernCol>
                <KernCol Span="12" SpanMd="6">
                    <KernButton Variant="ButtonVariant.Primary" OnClick="NextStep" Block="true">Weiter</KernButton>
                </KernCol>
            </KernRow>
        </ComponentSection>
    }
    else if (_currentStep == 3)
    {
        <ComponentSection Title="Schritt 3 – Zusammenfassung" Description="Bitte prüfen Sie Ihre Angaben.">
            <KernSummaryGroup>
                <KernSummary Number="1"
                             Title="Persönliche Daten"
                             EditHref="#"
                             EditLabel="Bearbeiten">
                    <KernDescriptionList Layout="DescriptionListLayout.Row">
                        <KernDescriptionItem Key="Anrede" Value="@(_anrede ?? "-")" />
                        <KernDescriptionItem Key="Vorname" Value="@(_vorname ?? "-")" />
                        <KernDescriptionItem Key="Nachname" Value="@(_nachname ?? "-")" />
                        <KernDescriptionItem Key="E-Mail" Value="@(_email ?? "-")" />
                        <KernDescriptionItem Key="Telefon" Value="@(_telefon ?? "-")" />
                        <KernDescriptionItem Key="Geburtsdatum" Value="@GetFormattedBirthdate()" />
                    </KernDescriptionList>
                </KernSummary>

                <KernSummary Number="2"
                             Title="Adressdaten"
                             EditHref="#"
                             EditLabel="Bearbeiten">
                    <KernDescriptionList Layout="DescriptionListLayout.Row">
                        <KernDescriptionItem Key="Straße" Value="@($"{_strasse} {_hausnummer}")" />
                        <KernDescriptionItem Key="PLZ / Ort" Value="@($"{_plz} {_ort}")" />
                        <KernDescriptionItem Key="Bundesland" Value="@GetBundeslandLabel()" />
                        @if (_abweichendeAdresse)
                        {
                            <KernDescriptionItem Key="Postadresse" Value="@($"{_postStrasse} {_postHausnummer}, {_postPlz} {_postOrt}")" />
                        }
                    </KernDescriptionList>
                </KernSummary>
            </KernSummaryGroup>

            <KernDivider />

            <KernCheckbox Label="Ich bestätige die Richtigkeit der Angaben"
                          Checked="@_bestaetigt"
                          CheckedChanged="@(value => _bestaetigt = value)"
                          Error="@GetValidationError(nameof(_bestaetigt))" />

            <KernRow>
                <KernCol Span="12" SpanMd="6">
                    <KernButton Variant="ButtonVariant.Secondary" OnClick="PreviousStep" Block="true">Zurück</KernButton>
                </KernCol>
                <KernCol Span="12" SpanMd="6">
                    <KernButton Variant="ButtonVariant.Primary" OnClick="SubmitAntrag" Block="true" Disabled="@(!_bestaetigt)">Antrag absenden</KernButton>
                </KernCol>
            </KernRow>
        </ComponentSection>
    }
    else if (_currentStep == 4)
    {
        <ComponentSection Title="Bestätigung" Description="Ihr Antrag wurde erfolgreich eingereicht.">
            <KernAlert Type="AlertType.Success" Title="Antrag erfolgreich eingereicht">
                Ihre Antragsnummer lautet: <strong>ANT-2026-@_antragsnummer</strong><br />
                Sie erhalten in Kürze eine Bestätigungs-E-Mail an <strong>@_email</strong>.
            </KernAlert>

            <KernTaskList Title="Nächste Schritte">
                <KernTaskListItem Number="1" Title="Bestätigungs-E-Mail prüfen" Href="#">
                    <StatusContent>
                        <KernBadge Variant="BadgeVariant.Info">Ausstehend</KernBadge>
                    </StatusContent>
                </KernTaskListItem>
                <KernTaskListItem Number="2" Title="Unterlagen hochladen" Href="#">
                    <StatusContent>
                        <KernBadge Variant="BadgeVariant.Warning">Offen</KernBadge>
                    </StatusContent>
                </KernTaskListItem>
                <KernTaskListItem Number="3" Title="Bearbeitungsstatus prüfen" Href="#">
                    <StatusContent>
                        <KernBadge Variant="BadgeVariant.Info">In ca. 2 Wochen</KernBadge>
                    </StatusContent>
                </KernTaskListItem>
            </KernTaskList>

            <KernButton Variant="ButtonVariant.Primary" OnClick="ResetAntrag">Neuen Antrag starten</KernButton>
        </ComponentSection>
    }
</KernContainer>

@code {
    private int _currentStep = 1;
    private Dictionary<string, string> _validationErrors = new();

    // Schritt 1: Persönliche Daten
    private string? _anrede = "herr";
    private string? _vorname;
    private string? _nachname;
    private string? _email;
    private string? _telefon;
    private string? _geburtstagTag;
    private string? _geburtstagMonat;
    private string? _geburtstagJahr;

    // Schritt 2: Adressdaten
    private string? _strasse;
    private string? _hausnummer;
    private string? _plz;
    private string? _ort;
    private string? _bundesland = "be";
    private bool _abweichendeAdresse;
    private string? _postStrasse;
    private string? _postHausnummer;
    private string? _postPlz;
    private string? _postOrt;

    // Schritt 3: Bestätigung
    private bool _bestaetigt;

    // Schritt 4: Antragsnummer
    private string? _antragsnummer;

    private static readonly IReadOnlyList<KernRadioItem> _anredeOptions =
    [
        new("herr", "Herr"),
        new("frau", "Frau"),
        new("divers", "Divers")
    ];

    private static readonly IReadOnlyList<KernSelectOption> _bundeslaender =
    [
        new("bw", "Baden-Württemberg"),
        new("by", "Bayern"),
        new("be", "Berlin"),
        new("bb", "Brandenburg"),
        new("hb", "Bremen"),
        new("hh", "Hamburg"),
        new("he", "Hessen"),
        new("mv", "Mecklenburg-Vorpommern"),
        new("ni", "Niedersachsen"),
        new("nw", "Nordrhein-Westfalen"),
        new("rp", "Rheinland-Pfalz"),
        new("sl", "Saarland"),
        new("sn", "Sachsen"),
        new("st", "Sachsen-Anhalt"),
        new("sh", "Schleswig-Holstein"),
        new("th", "Thüringen")
    ];

    private Task NextStep(MouseEventArgs _)
    {
        _validationErrors.Clear();

        if (_currentStep == 1 && !ValidateStep1())
        {
            return Task.CompletedTask;
        }

        if (_currentStep == 2 && !ValidateStep2())
        {
            return Task.CompletedTask;
        }

        _currentStep++;
        return Task.CompletedTask;
    }

    private Task PreviousStep(MouseEventArgs _)
    {
        _validationErrors.Clear();
        _currentStep--;
        return Task.CompletedTask;
    }

    private Task SubmitAntrag(MouseEventArgs _)
    {
        if (!_bestaetigt)
        {
            _validationErrors[nameof(_bestaetigt)] = "Bitte bestätigen Sie die Richtigkeit Ihrer Angaben.";
            return Task.CompletedTask;
        }

        _antragsnummer = new Random().Next(100000, 999999).ToString();
        _currentStep = 4;
        return Task.CompletedTask;
    }

    private Task CancelAntrag(MouseEventArgs args)
    {
        return ResetAntrag(args);
    }

    private Task ResetAntrag(MouseEventArgs _)
    {
        _currentStep = 1;
        _validationErrors.Clear();

        _anrede = "herr";
        _vorname = null;
        _nachname = null;
        _email = null;
        _telefon = null;
        _geburtstagTag = null;
        _geburtstagMonat = null;
        _geburtstagJahr = null;

        _strasse = null;
        _hausnummer = null;
        _plz = null;
        _ort = null;
        _bundesland = "be";
        _abweichendeAdresse = false;
        _postStrasse = null;
        _postHausnummer = null;
        _postPlz = null;
        _postOrt = null;

        _bestaetigt = false;
        _antragsnummer = null;

        return Task.CompletedTask;
    }

    private bool ValidateStep1()
    {
        var isValid = true;

        if (string.IsNullOrWhiteSpace(_vorname))
        {
            _validationErrors[nameof(_vorname)] = "Vorname ist ein Pflichtfeld.";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(_nachname))
        {
            _validationErrors[nameof(_nachname)] = "Nachname ist ein Pflichtfeld.";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(_email))
        {
            _validationErrors[nameof(_email)] = "E-Mail-Adresse ist ein Pflichtfeld.";
            isValid = false;
        }
        else if (!_email.Contains("@"))
        {
            _validationErrors[nameof(_email)] = "Bitte geben Sie eine gültige E-Mail-Adresse ein.";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(_geburtstagTag) || string.IsNullOrWhiteSpace(_geburtstagMonat) || string.IsNullOrWhiteSpace(_geburtstagJahr))
        {
            _validationErrors[nameof(_geburtstagTag)] = "Geburtsdatum ist ein Pflichtfeld.";
            isValid = false;
        }

        return isValid;
    }

    private bool ValidateStep2()
    {
        var isValid = true;

        if (string.IsNullOrWhiteSpace(_strasse))
        {
            _validationErrors[nameof(_strasse)] = "Straße ist ein Pflichtfeld.";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(_hausnummer))
        {
            _validationErrors[nameof(_hausnummer)] = "Hausnummer ist ein Pflichtfeld.";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(_plz))
        {
            _validationErrors[nameof(_plz)] = "PLZ ist ein Pflichtfeld.";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(_ort))
        {
            _validationErrors[nameof(_ort)] = "Ort ist ein Pflichtfeld.";
            isValid = false;
        }

        if (string.IsNullOrWhiteSpace(_bundesland))
        {
            _validationErrors[nameof(_bundesland)] = "Bundesland ist ein Pflichtfeld.";
            isValid = false;
        }

        return isValid;
    }

    private string? GetValidationError(string fieldName)
    {
        return _validationErrors.TryGetValue(fieldName, out var error) ? error : null;
    }

    private string GetFormattedBirthdate()
    {
        if (string.IsNullOrWhiteSpace(_geburtstagTag) || string.IsNullOrWhiteSpace(_geburtstagMonat) || string.IsNullOrWhiteSpace(_geburtstagJahr))
        {
            return "-";
        }

        return $"{_geburtstagTag}.{_geburtstagMonat}.{_geburtstagJahr}";
    }

    private string GetBundeslandLabel()
    {
        return _bundeslaender.FirstOrDefault(b => b.Value == _bundesland)?.Label ?? "-";
    }
}

