@page "/components/navigation"

<PageTitle>Navigation - PublicKernBlazor.Components Showcase</PageTitle>

<KernContainer>
    <KernHeading Level="HeadingLevel.Large" Element="h1">Navigation</KernHeading>
    <KernBody Muted="true">Kopfzeile, Links und Listen für Navigations- und Inhaltsstrukturen.</KernBody>

    <ComponentSection Title="KernKopfzeile" Description="Default, Fluid und benutzerdefinierte Beschriftung.">
        <div class="demo-nav-header-sample">
            <KernKopfzeile />
        </div>
        <div class="demo-nav-header-sample">
            <KernKopfzeile Fluid="true" />
        </div>
        <div class="demo-nav-header-sample">
            <KernKopfzeile Label="Offizieller Service der Musterstadt" />
        </div>
    </ComponentSection>

    <ComponentSection Title="KernLink" Description="Standard-Link, neues Fenster und stretched Link.">
        <KernList Variant="KernListVariant.Bullet">
            <li><KernLink Href="/components/typography">Interner Link zur Typografie-Seite</KernLink></li>
            <li><KernLink Href="https://www.kern-ux.de" Target="_blank">Externer Link im neuen Fenster</KernLink></li>
        </KernList>

        <KernCard Active="true" class="demo-stretched-card">
            <KernCardContainer Title="Stretched Link Beispiel">
                <KernBody>Die gesamte Kartenfläche wird über den Link bedienbar.</KernBody>
                <KernLink Href="/components/content" Stretched="true">Zum Content-Showcase</KernLink>
            </KernCardContainer>
        </KernCard>
    </ComponentSection>

    <ComponentSection Title="KernList" Description="Default-, Bullet- und Number-Varianten inklusive Horizontalmodus.">
        <KernTitle Size="TitleSize.Small">Default</KernTitle>
        <KernList>
            <li>Eintrag A</li>
            <li>Eintrag B</li>
            <li>Eintrag C</li>
        </KernList>

        <KernTitle Size="TitleSize.Small">Bullet</KernTitle>
        <KernList Variant="KernListVariant.Bullet">
            <li>Barrierefrei</li>
            <li>Typsicher</li>
            <li>KERN-konform</li>
        </KernList>

        <KernTitle Size="TitleSize.Small">Number</KernTitle>
        <KernList Variant="KernListVariant.Number">
            <li>Daten erfassen</li>
            <li>Daten prüfen</li>
            <li>Antrag absenden</li>
        </KernList>

        <KernTitle Size="TitleSize.Small">Horizontal</KernTitle>
        <KernList Variant="KernListVariant.Bullet" Horizontal="true">
            <li>Start</li>
            <li>Komponenten</li>
            <li>Beispiele</li>
            <li>Kontakt</li>
        </KernList>
    </ComponentSection>
</KernContainer>
