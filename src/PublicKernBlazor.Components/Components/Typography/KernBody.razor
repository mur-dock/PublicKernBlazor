@namespace PublicKernBlazor.Components.Components.Typography
@using PublicKernBlazor.Components.Enums
@using PublicKernBlazor.Components.Utilities

<p class="@CssClass" @attributes="AdditionalAttributes">@ChildContent</p>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public Size Size { get; set; } = Size.Default;

    [Parameter]
    public bool Bold { get; set; }

    [Parameter]
    public bool Muted { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string CssClass => new CssBuilder("kern-body")
        .AddClass("kern-body--small", Size == Size.Small)
        .AddClass("kern-body--large", Size == Size.Large)
        .AddClass("kern-body--bold", Bold)
        .AddClass("kern-body--muted", Muted)
        .AddClassFromAttributes(AdditionalAttributes)
        .Build();
}

