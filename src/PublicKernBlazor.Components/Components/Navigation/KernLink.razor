@namespace PublicKernBlazor.Components.Components.Navigation

<a href="@ResolvedHref"
   target="@Target"
   rel="@ResolvedRel"
   class="@CssClass"
   @attributes="AdditionalAttributes">
    @ChildContent
</a>

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string? Href { get; set; } = "#";

    [Parameter]
    public string? Target { get; set; }

    [Parameter]
    public string? Rel { get; set; }

    [Parameter]
    public bool Stretched { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedHref => string.IsNullOrWhiteSpace(Href) ? "#" : Href;

    private string CssClass => new CssBuilder("kern-link")
        .AddClass("kern-link--stretched", Stretched)
        .AddClassFromAttributes(AdditionalAttributes)
        .Build();

    private string? ResolvedRel
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(Rel))
            {
                return Rel;
            }

            return string.Equals(Target, "_blank", StringComparison.OrdinalIgnoreCase)
                ? "noreferrer noopener"
                : null;
        }
    }
}

