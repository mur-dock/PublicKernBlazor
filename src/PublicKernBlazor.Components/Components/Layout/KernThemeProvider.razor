@namespace PublicKernBlazor.Components.Components.Layout
@using PublicKernBlazor.Components.Enums
@using PublicKernBlazor.Components.Services
@implements IDisposable
@inject ThemeService ThemeService

<div data-kern-theme="@ThemeService.AttributeValue"
     @attributes="AdditionalAttributes">
    @ChildContent
</div>

@code {
    // _lastThemeParameter merkt sich den zuletzt vom Eltern-Element übergebenen Theme-Wert.
    // So erkennt OnParametersSet, ob sich der Parameter tatsächlich geändert hat,
    // und überschreibt nicht den Service-Zustand bei jedem Re-Render.
    // Ohne dieses Tracking würde ein ThemeService.Toggle() sofort rückgängig gemacht,
    // weil OnParametersSet den Service blind auf den (unveränderten) Parameter zurücksetzt.
    private KernTheme _lastThemeParameter;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public KernTheme Theme { get; set; } = KernTheme.Light;

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    protected override void OnInitialized()
    {
        ThemeService.ThemeChanged += HandleThemeChanged;
    }

    protected override void OnParametersSet()
    {
        // Nur wenn sich der Theme-Parameter von außen geändert hat, den Service aktualisieren.
        // Bei einem Re-Render durch HandleThemeChanged (ausgelöst durch Toggle) bleibt
        // Theme == _lastThemeParameter, sodass der Service-Zustand nicht überschrieben wird.
        if (Theme != _lastThemeParameter)
        {
            _lastThemeParameter = Theme;
            ThemeService.Set(Theme);
        }
    }

    private void HandleThemeChanged(KernTheme _)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        ThemeService.ThemeChanged -= HandleThemeChanged;
    }
}
