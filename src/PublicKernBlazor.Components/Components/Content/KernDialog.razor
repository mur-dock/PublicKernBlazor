@namespace PublicKernBlazor.Components.Components.Content
@using Microsoft.JSInterop

@* KernDialog benötigt JS-Interop für das native <dialog>-Element (showModal/close).
   Dies ist eine der wenigen Stellen, an denen JavaScript technisch unvermeidbar ist,
   da Blazor keine native API für das HTML-<dialog>-Element bereitstellt.
   
   Voraussetzung: wwwroot/js/kern-dialog.js muss im Host-Dokument (App.razor) eingebunden sein:
   <script src="_content/PublicKernBlazor.Components/js/kern-dialog.js"></script>
   
   Hinweis: Das frühere HTMLDialogElement.prototype.showModal.call-Muster wurde bewusst
   durch stabile eigene JS-Funktionen (window.kernDialog) ersetzt, da das Prototype-Muster
   je nach Blazor-Runtime-Version und Browser-Umgebung unzuverlässig ist. *@

<dialog class="@CssClass"
        @ref="_dialogRef"
        @attributes="AdditionalAttributes">
    <header class="kern-dialog__header">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
            <h2 class="kern-title">@Title</h2>
        }
        <button type="button"
                class="kern-btn kern-btn--tertiary"
                title="Schließen"
                aria-label="Dialog schließen"
                @onclick="HandleClose">
            <KernIcon Glyph="KernIconGlyph.Close" AriaHidden="true" />
        </button>
    </header>

    @if (ChildContent is not null)
    {
        <section class="kern-dialog__body">
            @ChildContent
        </section>
    }

    @if (FooterContent is not null)
    {
        <footer class="kern-dialog__footer">
            @FooterContent
        </footer>
    }
</dialog>

@code {
    private ElementReference _dialogRef;

    /// <summary>Titel des Dialogs, wird im Header gerendert.</summary>
    [Parameter]
    public string? Title { get; set; }

    /// <summary>
    /// Steuert die Sichtbarkeit des Dialogs. Verwendet intern <c>showModal()</c>/<c>close()</c>
    /// über JS-Interop, da Blazor keine native API für <c>&lt;dialog&gt;</c> bereitstellt.
    /// </summary>
    [Parameter]
    public bool Open { get; set; }

    /// <summary>Wird ausgelöst, wenn der Nutzer den Dialog schließt.</summary>
    [Parameter]
    public EventCallback OnClose { get; set; }

    /// <summary>Inhalt des Dialog-Body.</summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>Inhalt des Dialog-Footers (typischerweise Buttons).</summary>
    [Parameter]
    public RenderFragment? FooterContent { get; set; }

    /// <summary>Zusätzliche HTML-Attribute für das <c>&lt;dialog&gt;</c>-Element.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    private string CssClass => new CssBuilder("kern-dialog")
        .AddClassFromAttributes(AdditionalAttributes)
        .Build();

    // _lastOpen verfolgt den letzten bekannten Open-Zustand, um showModal/close
    // nur bei tatsächlicher Änderung aufzurufen (verhindert doppelte Aufrufe).
    private bool _lastOpen;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (Open != _lastOpen)
        {
            _lastOpen = Open;
            if (Open)
            {
                // kernDialog.showModal ist eine stabile JS-Hilfsfunktion aus wwwroot/js/kern-dialog.js.
                // Sie ruft intern el.showModal() auf und prüft vorher die Existenz der Methode.
                await JS.InvokeVoidAsync("kernDialog.showModal", _dialogRef);
            }
            else
            {
                await JS.InvokeVoidAsync("kernDialog.close", _dialogRef);
            }
        }
    }

    private async Task HandleClose()
    {
        await OnClose.InvokeAsync();
    }
}

