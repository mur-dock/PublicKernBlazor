@namespace PublicKernBlazor.Components.Components.Forms
@inject IdGeneratorService IdGenerator

<KernFieldset Legend="@Legend"
              Hint="@Hint"
              Error="@Error"
              Id="@ResolvedFieldsetId"
              Horizontal="@Horizontal"
              AdditionalAttributes="@AdditionalAttributes">
    @for (var index = 0; index < ResolvedItems.Count; index++)
    {
        var item = ResolvedItems[index];
        var inputId = $"{ResolvedFieldsetId}-{index}";
        <div class="@ItemCssClass">
            <input id="@inputId"
                   class="@ItemInputCssClass"
                   type="checkbox"
                   checked="@IsSelected(item.Value)"
                   value="@item.Value"
                   disabled="@item.Disabled"
                   @onchange="@(args => HandleItemChanged(item.Value, args))" />
            <label class="kern-label" for="@inputId">@item.Label</label>
        </div>
    }
</KernFieldset>

@code {
    private string? _generatedId;
    
    // _materializedItems wird einmalig pro Render-Zyklus in OnParametersSet befüllt.
    // Das vermeidet die Neuallokation bei jedem Property-Zugriff auf ResolvedItems,
    // was bei großen Listen zu erheblichem Performance-Overhead führen würde.
    private List<KernCheckboxItem> _materializedItems = [];

    [Parameter] public string Legend { get; set; } = string.Empty;
    [Parameter] public IEnumerable<KernCheckboxItem> Items { get; set; } = [];
    [Parameter] public IReadOnlyCollection<string>? SelectedValues { get; set; }
    [Parameter] public EventCallback<IReadOnlyCollection<string>> SelectedValuesChanged { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool Horizontal { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private IReadOnlyList<KernCheckboxItem> ResolvedItems => _materializedItems;

    private string ResolvedFieldsetId => string.IsNullOrWhiteSpace(Id) ? _generatedId ?? "kern-checkbox-list" : Id;

    private string ItemCssClass => new CssBuilder("kern-form-check")
        .AddClass("kern-form-check--error", !string.IsNullOrWhiteSpace(Error))
        .Build();

    private string ItemInputCssClass => new CssBuilder("kern-form-check__checkbox")
        .AddClass("kern-form-check__checkbox--error", !string.IsNullOrWhiteSpace(Error))
        .Build();

    protected override void OnInitialized()
    {
        _generatedId = IdGenerator.Create("kern-checkbox-list");
    }

    protected override void OnParametersSet()
    {
        _materializedItems = [.. Items];
    }

    private bool IsSelected(string value) => SelectedValues?.Contains(value) == true;

    private async Task HandleItemChanged(string value, ChangeEventArgs args)
    {
        var selected = new HashSet<string>(SelectedValues ?? []);
        var isChecked = args.Value is bool checkedValue && checkedValue;

        if (isChecked)
        {
            selected.Add(value);
        }
        else
        {
            selected.Remove(value);
        }

        await SelectedValuesChanged.InvokeAsync([.. selected]);
    }
}

