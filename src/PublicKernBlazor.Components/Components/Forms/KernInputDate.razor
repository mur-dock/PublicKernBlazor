@namespace PublicKernBlazor.Components.Components.Forms

<KernFormField Label="@Label"
               InputId="@Id"
               Hint="@Hint"
               Error="@Error"
               Optional="@Optional"
               OptionalText="@OptionalText"
               Disabled="@Disabled"
               AdditionalAttributes="@AdditionalAttributes"
               FieldContent="@RenderFields" />

@code {
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Day { get; set; }
    [Parameter] public EventCallback<string?> DayChanged { get; set; }
    [Parameter] public string? Month { get; set; }
    [Parameter] public EventCallback<string?> MonthChanged { get; set; }
    [Parameter] public string? Year { get; set; }
    [Parameter] public EventCallback<string?> YearChanged { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool Optional { get; set; }
    [Parameter] public string? OptionalText { get; set; } = "- Optional";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private RenderFragment<KernFormFieldContext> RenderFields => context => @<div class="kern-row">
        <div class="kern-col-4">
            <input id="@($"{context.InputId}-day")"
                   class="@InputCssClass(context, "kern-form-input__input--width-2")"
                   type="text"
                   inputmode="numeric"
                   value="@Day"
                   placeholder="TT"
                   aria-label="Tag"
                   aria-describedby="@context.AriaDescribedBy"
                   disabled="@context.Disabled"
                   @oninput="HandleDay" />
        </div>
        <div class="kern-col-4">
            <input id="@($"{context.InputId}-month")"
                   class="@InputCssClass(context, "kern-form-input__input--width-2")"
                   type="text"
                   inputmode="numeric"
                   value="@Month"
                   placeholder="MM"
                   aria-label="Monat"
                   aria-describedby="@context.AriaDescribedBy"
                   disabled="@context.Disabled"
                   @oninput="HandleMonth" />
        </div>
        <div class="kern-col-4">
            <input id="@($"{context.InputId}-year")"
                   class="@InputCssClass(context, "kern-form-input__input--width-4")"
                   type="text"
                   inputmode="numeric"
                   value="@Year"
                   placeholder="JJJJ"
                   aria-label="Jahr"
                   aria-describedby="@context.AriaDescribedBy"
                   disabled="@context.Disabled"
                   @oninput="HandleYear" />
        </div>
    </div>;

    private static string InputCssClass(KernFormFieldContext context, string widthClass) => new CssBuilder("kern-form-input__input")
        .AddClass(widthClass)
        .AddClass("kern-form-input__input--error", context.HasError)
        .Build();

    private async Task HandleDay(ChangeEventArgs args) => await DayChanged.InvokeAsync(Convert.ToString(args.Value, System.Globalization.CultureInfo.InvariantCulture));
    private async Task HandleMonth(ChangeEventArgs args) => await MonthChanged.InvokeAsync(Convert.ToString(args.Value, System.Globalization.CultureInfo.InvariantCulture));
    private async Task HandleYear(ChangeEventArgs args) => await YearChanged.InvokeAsync(Convert.ToString(args.Value, System.Globalization.CultureInfo.InvariantCulture));
}

