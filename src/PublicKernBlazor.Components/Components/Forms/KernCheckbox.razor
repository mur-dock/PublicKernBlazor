@namespace PublicKernBlazor.Components.Components.Forms
@inject IdGeneratorService IdGenerator

<div class="@CssClass" @attributes="AdditionalAttributes">
    <input id="@ResolvedId"
           name="@Name"
           class="@InputCssClass"
           type="checkbox"
           checked="@Checked"
           aria-describedby="@ResolvedAriaDescribedBy"
           disabled="@Disabled"
           @onchange="HandleChanged" />
    <label class="kern-label" for="@ResolvedId">@Label</label>

    @if (!string.IsNullOrWhiteSpace(Hint))
    {
        <div class="kern-hint" id="@ResolvedHintId">@Hint</div>
    }

    @if (!string.IsNullOrWhiteSpace(Error))
    {
        <p class="kern-error" id="@ResolvedErrorId" role="alert">
            <KernIcon Glyph="KernIconGlyph.Danger" AriaHidden="true" />
            <span class="kern-body">@Error</span>
        </p>
    }
</div>

@code {
    private string? _generatedId;

    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public bool Checked { get; set; }
    [Parameter] public EventCallback<bool> CheckedChanged { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Hint { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public string? Id { get; set; }
    [Parameter] public string? Name { get; set; }
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedId => string.IsNullOrWhiteSpace(Id) ? _generatedId ?? "kern-checkbox" : Id;

    private string? ResolvedHintId => string.IsNullOrWhiteSpace(Hint) ? null : $"{ResolvedId}-hint";

    private string? ResolvedErrorId => string.IsNullOrWhiteSpace(Error) ? null : $"{ResolvedId}-error";

    private string? ResolvedAriaDescribedBy
    {
        get
        {
            var ids = new List<string>(2);
            if (!string.IsNullOrWhiteSpace(ResolvedHintId))
            {
                ids.Add(ResolvedHintId);
            }

            if (!string.IsNullOrWhiteSpace(ResolvedErrorId))
            {
                ids.Add(ResolvedErrorId);
            }

            return ids.Count == 0 ? null : string.Join(" ", ids);
        }
    }

    private string CssClass => new CssBuilder("kern-form-check")
        .AddClass("kern-form-check--error", !string.IsNullOrWhiteSpace(Error))
        .AddClassFromAttributes(AdditionalAttributes)
        .Build();

    private string InputCssClass => new CssBuilder("kern-form-check__checkbox")
        .AddClass("kern-form-check__checkbox--error", !string.IsNullOrWhiteSpace(Error))
        .Build();

    protected override void OnInitialized()
    {
        _generatedId = IdGenerator.Create("kern-checkbox");
    }

    private async Task HandleChanged(ChangeEventArgs args)
    {
        var isChecked = args.Value is bool checkedValue && checkedValue;
        await CheckedChanged.InvokeAsync(isChecked);
    }
}

